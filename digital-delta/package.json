{
  "name": "digital-delta",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "proto:build": "node -e \"require('fs').mkdirSync(require('path').join('src','proto'),{recursive:true})\" && npx pbjs -t static-module -w commonjs -o src/proto/bundle.js proto/digitaldelta.proto"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "moti": "^0.30.0",
    "nativewind": "^4.2.1",
    "protobufjs": "^8.0.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "tailwindcss": "^3.4.17",
    "tweetnacl": "^1.0.3",
